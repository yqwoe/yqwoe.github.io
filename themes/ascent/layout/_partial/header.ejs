<header id="header">
  <nav>
    <div class="header-nav-links">
      <a class="nav-link-first" href="<%- url_for() %>"><%= config.title %></a>
      <span class="nav-spacer"></span>
      <% var keys = Object.keys(theme.menu); %>
      <% for (var i = 0; i < keys.length; i++){ %>
        <% if (i !== 0){ %>
          <span class="nav-spacer"> </span>
        <% } %>
        <a class="nav-link" href="<%- url_for(theme.menu[keys[i]]) %>"><%= __(keys[i]) %></a>
      <% } %>
      <% if (theme.rss){ %>
        <span class="nav-spacer"> </span>
        <a class="nav-link" href="<%- url_for(theme.rss) %>"><%= __('rss_feed') %></a>
      <% } %>
    </div>
    <div class="poem-wrap">
      <p id="poem">加载中...</p>
      <p id="info"/>
    </div>
  </nav>
</header>
