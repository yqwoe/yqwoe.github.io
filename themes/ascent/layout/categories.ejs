<%
  page.layout === 'categories'
  page.title = '分类'
%>

<div class="categories-wrapper">
  <h3 class="list-header"><%= site.categories.length || 0 %> 分类 </h3>
  <div class="list-group category-wrapper">
    <% site.categories.sort(function(a,b){return parseInt(a.posts.length) - parseInt(b.posts.length);}).each(function(category) { %>
      <div class="category-group-item">
        <a class="category" href="<%= url_for(category.path) %>">
          <%= category.name %>
        </a>
        <a class="category-count" href="<%= url_for(category.path) %>">
          <%= category.posts.length || 0 %>
        </a>
      </div>
    <% }) %>
  </ul>
</div>
